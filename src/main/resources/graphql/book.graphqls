type Query {
    books: [Book!]!
    book(id: ID!): Book
    booksByGenre(genre: String!): [Book!]!
    booksByTitle(title: String!): [Book!]!
    booksByYearRange(from: Int!, to: Int!): [Book!]!
}

type Book {
    id: ID!
    title: String!
    genre: String!
    publishedYear: Int
    author: Author
}
